# =======================================================
# Variables d'environnement Luxclean Services
# Copier ce fichier en .env et adapter les valeurs.
# =======================================================

# --- Base de données PostgreSQL (Tâche 1.2) ---
DB_NAME=luxclean_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# --- Django ---
SECRET_KEY=change-me-please-in-production
DEBUG=True
ALLOWED_HOSTS=*

# --- Frontend (injecté dans le conteneur frontend) ---
VITE_API_URL=http://localhost:8000/api
